# Site URL — used for canonical URLs, Open Graph, and schema.org structured data
NEXT_PUBLIC_SITE_URL=https://www.kdmcolor.com.br

# Google Maps — required for the dealer locator map (/revendedores)
# Enable "Maps JavaScript API" in Google Cloud Console, and create a Map ID
# under Maps Platform > Map Management (needed for AdvancedMarker to work).
# Without these two set, the map gracefully shows a "not configured" message
# instead of crashing the page.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
